---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Posts" activeNav="posts">
  <p class="section-label">Blog posts — {allPosts.length} articles</p>
  <div class="post-list">
    {allPosts.map((post, i) => (
      <a href={`${import.meta.env.BASE_URL}posts/${post.id}/`} class="post-card" style={`animation-delay: ${i * 0.06}s`}>
        <p class="post-title">{post.data.title}</p>
        {post.data.description && <p class="post-desc">{post.data.description}</p>}
        <div class="post-meta">
          <span>{new Date(post.data.date).toLocaleDateString('vi-VN')}</span>
          {post.data.tags?.map(tag => (
            <span class="post-tag">{tag}</span>
          ))}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
