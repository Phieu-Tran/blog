---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const films = await getCollection('films');
  return films.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}

const allPosts = (await getCollection('posts')).filter(p => !p.data.draft);
const { entry } = Astro.props;
const { title, imdb_id, tmdb_id, rating, imdb_score, tmdb_score, genre, year, director, status, cover, date } = entry.data;

const titleLower = title.toLowerCase();
const titleWords = titleLower.split(/[\s:,|—]+/).filter(w => w.length > 3);
const relatedPosts = allPosts.filter(p => {
  const pt = p.data.title.toLowerCase();
  return titleWords.some(w => pt.includes(w)) || pt.includes(titleLower);
});
const myStars = Math.round(rating / 2);
const imdbStars = Math.round((imdb_score || 0) / 2);
const tmdbStars = Math.round((tmdb_score || 0) / 2);

const imdbUrl = imdb_id
  ? `https://www.imdb.com/title/${imdb_id}`
  : `https://www.imdb.com/find/?q=${encodeURIComponent(title)}`;
const tmdbUrl = tmdb_id
  ? `https://www.themoviedb.org/movie/${tmdb_id}`
  : `https://www.themoviedb.org/search?query=${encodeURIComponent(title)}`;
---

<BaseLayout title={title} description={`${title} — ${genre}`} image={cover} activeNav="films">
  <a href={`${import.meta.env.BASE_URL}films/`} style="font-size:13px;color:rgba(255,255,255,0.4);display:inline-block;margin-bottom:16px;">
    ← Back to Films
  </a>

  <div style="display:flex;gap:24px;flex-wrap:wrap;">
    {/* Cover + links */}
    <div style="flex-shrink:0;">
      {cover && <img src={cover} alt={title} style="width:220px;border-radius:12px;" />}
      <a href={imdbUrl} target="_blank" rel="noopener noreferrer"
        style="display:block;text-align:center;margin-top:10px;padding:8px;border-radius:8px;background:rgba(245,197,24,0.12);border:1px solid rgba(245,197,24,0.3);color:#F5C518;font-size:12px;font-weight:600;transition:all 0.2s;">
        {imdb_id ? 'View on IMDB ↗' : 'Search on IMDB ↗'}
      </a>
      <a href={tmdbUrl} target="_blank" rel="noopener noreferrer"
        style="display:block;text-align:center;margin-top:6px;padding:8px;border-radius:8px;background:rgba(1,180,228,0.12);border:1px solid rgba(1,180,228,0.3);color:#01B4E4;font-size:12px;font-weight:600;transition:all 0.2s;">
        {tmdb_id ? 'View on TMDB ↗' : 'Search on TMDB ↗'}
      </a>
    </div>

    {/* Info */}
    <div style="flex:1;min-width:280px;">
      {/* Badges */}
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
        <span class="badge badge-film">Film</span>
        <span class="badge" style="background:rgba(255,255,255,0.06);color:var(--text-secondary);">
          {status === 'watched' ? 'Watched' : 'Plan to Watch'}
        </span>
      </div>

      <h1 style="font-size:26px;font-weight:700;margin:0 0 4px;">{title}</h1>
      <p style="font-size:13px;color:var(--text-muted);margin:0 0 20px;">
        {genre} · {year} · {director}
      </p>

      {/* 3 Scores */}
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:24px;">
        <div style="background:rgba(255,255,255,0.03);border-radius:10px;padding:12px 10px;text-align:center;">
          <p style="font-size:10px;color:var(--text-muted);margin:0 0 4px;text-transform:uppercase;letter-spacing:0.5px;font-family:'Space Mono',monospace;">My Score</p>
          <p style="font-size:22px;font-weight:700;color:var(--star-color);margin:0;">
            {rating > 0 ? rating : '—'}
          </p>
          <div class="stars" style="margin-top:4px;">
            {[...Array(5)].map((_, i) => (
              <span class={i < myStars ? 'star-on' : 'star-off'}>★</span>
            ))}
          </div>
        </div>
        <div style="background:rgba(255,255,255,0.03);border-radius:10px;padding:12px 10px;text-align:center;">
          <p style="font-size:10px;color:var(--text-muted);margin:0 0 4px;text-transform:uppercase;letter-spacing:0.5px;font-family:'Space Mono',monospace;">IMDB</p>
          <p style="font-size:22px;font-weight:700;color:#F5C518;margin:0;">
            {imdb_score ? imdb_score.toFixed(1) : '—'}
          </p>
          <div class="stars" style="margin-top:4px;">
            {[...Array(5)].map((_, i) => (
              <span class={i < imdbStars ? 'star-on' : 'star-off'}>★</span>
            ))}
          </div>
        </div>
        <div style="background:rgba(255,255,255,0.03);border-radius:10px;padding:12px 10px;text-align:center;">
          <p style="font-size:10px;color:var(--text-muted);margin:0 0 4px;text-transform:uppercase;letter-spacing:0.5px;font-family:'Space Mono',monospace;">TMDB</p>
          <p style="font-size:22px;font-weight:700;color:#01B4E4;margin:0;">
            {tmdb_score ? tmdb_score.toFixed(1) : '—'}
          </p>
          <div class="stars" style="margin-top:4px;">
            {[...Array(5)].map((_, i) => (
              <span class={i < tmdbStars ? 'star-on' : 'star-off'}>★</span>
            ))}
          </div>
        </div>
      </div>

      {/* Meta grid */}
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:24px;">
        <div style="background:rgba(255,255,255,0.03);border-radius:8px;padding:10px 12px;">
          <p style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin:0;">Director</p>
          <p style="font-size:13px;font-weight:500;margin:2px 0 0;">{director}</p>
        </div>
        <div style="background:rgba(255,255,255,0.03);border-radius:8px;padding:10px 12px;">
          <p style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin:0;">Year</p>
          <p style="font-size:13px;font-weight:500;margin:2px 0 0;">{year}</p>
        </div>
        <div style="background:rgba(255,255,255,0.03);border-radius:8px;padding:10px 12px;grid-column:span 2;">
          <p style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin:0;">Genre</p>
          <p style="font-size:13px;font-weight:500;margin:2px 0 0;">{genre}</p>
        </div>
      </div>

      {date && (
        <p style="font-size:11px;color:var(--text-muted);">
          Rated on {new Date(date).toLocaleDateString('vi-VN')}
        </p>
      )}
    </div>
  </div>

  {relatedPosts.length > 0 && (
    <section style="margin-top: 40px;">
      <p class="section-label">Bài viết liên quan</p>
      <hr class="section-divider" />
      <div class="post-list">
        {relatedPosts.map(post => (
          <a href={`${import.meta.env.BASE_URL}posts/${post.id}/`} class="post-card">
            <p class="post-title">{post.data.title}</p>
            {post.data.description && <p class="post-desc">{post.data.description}</p>}
            <div class="post-meta">
              <span>{new Date(post.data.date).toLocaleDateString('vi-VN')}</span>
              {post.data.tags?.map(tag => (
                <span class="post-tag">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
