---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const games = await getCollection('games');
  return games.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, rating, genre, year, studio, status, platform, cover } = entry.data;

const scoreColor = rating >= 9 ? '#34D399' : rating >= 7 ? '#FBBF24' : rating >= 5 ? '#FB923C' : '#EF4444';
const scoreLabel = rating >= 9 ? 'AMAZING' : rating >= 8 ? 'GREAT' : rating >= 7 ? 'GOOD' : rating >= 5 ? 'OKAY' : 'BAD';

const statusLabels: Record<string, string> = {
  playing: 'Playing', completed: 'Completed', plan: 'Backlog', dropped: 'Dropped',
};

const ignSearchUrl = `https://www.ign.com/search?q=${encodeURIComponent(title)}`;
---

<BaseLayout title={title} description={`${title} — ${genre}`} image={cover} activeNav="games">
  <a href={`${import.meta.env.BASE_URL}games/`} style="font-size:13px;color:rgba(255,255,255,0.4);display:inline-block;margin-bottom:16px;">
    ← Back to Games
  </a>

  <div style="display:flex;gap:24px;flex-wrap:wrap;">
    {/* Cover + links */}
    <div style="flex-shrink:0;">
      {cover && <img src={cover} alt={title} style="width:220px;border-radius:12px;" />}
      <a href={ignSearchUrl} target="_blank" rel="noopener noreferrer"
        style="display:block;text-align:center;margin-top:10px;padding:8px;border-radius:8px;background:rgba(191,35,42,0.15);border:1px solid rgba(191,35,42,0.3);color:#EF4444;font-size:12px;font-weight:600;transition:all 0.2s;">
        Search on IGN ↗
      </a>
    </div>

    {/* Info */}
    <div style="flex:1;min-width:280px;">
      {/* Badges */}
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap;">
        <span class="badge badge-game">Game</span>
        <span class="badge" style="background:rgba(255,255,255,0.06);color:var(--text-secondary);">
          {statusLabels[status]}
        </span>
        <span class="badge" style="background:rgba(255,255,255,0.06);color:var(--text-secondary);">
          {platform}
        </span>
      </div>

      <h1 style="font-size:26px;font-weight:700;margin:0 0 4px;">{title}</h1>
      <p style="font-size:13px;color:var(--text-muted);margin:0 0 20px;">
        {studio} · {year}
      </p>

      {/* Score — IGN style */}
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;background:rgba(255,255,255,0.03);border-radius:12px;padding:16px 20px;">
        <div style={`width:64px;height:64px;border-radius:12px;background:${scoreColor};display:flex;align-items:center;justify-content:center;flex-shrink:0;`}>
          <span style="font-size:24px;font-weight:800;color:#0a0a14;font-family:'Space Mono',monospace;">
            {rating}
          </span>
        </div>
        <div>
          <p style={`font-size:18px;font-weight:700;margin:0;color:${scoreColor};`}>{scoreLabel}</p>
          <p style="font-size:12px;color:var(--text-muted);margin:2px 0 0;">{genre}</p>
        </div>
      </div>

      {/* Meta */}
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:24px;">
        <div style="background:rgba(255,255,255,0.03);border-radius:8px;padding:10px 12px;">
          <p style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin:0;">Developer</p>
          <p style="font-size:13px;font-weight:500;margin:2px 0 0;">{studio}</p>
        </div>
        <div style="background:rgba(255,255,255,0.03);border-radius:8px;padding:10px 12px;">
          <p style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin:0;">Platform</p>
          <p style="font-size:13px;font-weight:500;margin:2px 0 0;">{platform}</p>
        </div>
        <div style="background:rgba(255,255,255,0.03);border-radius:8px;padding:10px 12px;">
          <p style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin:0;">Year</p>
          <p style="font-size:13px;font-weight:500;margin:2px 0 0;">{year}</p>
        </div>
        <div style="background:rgba(255,255,255,0.03);border-radius:8px;padding:10px 12px;">
          <p style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin:0;">Genre</p>
          <p style="font-size:13px;font-weight:500;margin:2px 0 0;">{genre.split(',')[0]}</p>
        </div>
      </div>

      {/* Review content */}
      <div class="prose">
        <Content />
      </div>
    </div>
  </div>
</BaseLayout>
