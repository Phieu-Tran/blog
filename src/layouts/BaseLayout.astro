---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  activeNav?: string;
}
const {
  title = 'mediaVault',
  description = 'Blog cá nhân tập hợp review game, anime, film',
  image,
  activeNav = 'home'
} = Astro.props;
const base = import.meta.env.BASE_URL;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageTitle = title === 'mediaVault' ? 'mediaVault' : `${title} — mediaVault`;
---
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  {image && <meta property="og:image" content={image} />}
  <ViewTransitions />

  <!-- Twitter -->
  <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  {image && <meta name="twitter:image" content={image} />}
</head>
<body>
  <nav class="nav">
    <div class="nav-logo">
      <a href={base} style="display:flex;align-items:center;gap:10px;">
        <div class="nav-logo-icon">M</div>
        <span class="nav-logo-text">mediaVault</span>
      </a>
    </div>
    <button class="nav-toggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-links">
      <a href={base} class={activeNav === 'home' ? 'active' : ''}>Trang chủ</a>
      <a href={`${base}anime/`} class={activeNav === 'anime' ? 'active' : ''}>Anime</a>
      <a href={`${base}games/`} class={activeNav === 'games' ? 'active' : ''}>Games</a>
      <a href={`${base}films/`} class={activeNav === 'films' ? 'active' : ''}>Films</a>
      <a href={`${base}steam/`} class={activeNav === 'steam' ? 'active' : ''} style="color:#66C0F4;">Steam</a>
      <a href={`${base}posts/`} class={activeNav === 'posts' ? 'active' : ''}>Posts</a>
    </div>
  </nav>

  <main class="container">
    <slot />
  </main>

  <footer style="border-top: 1px solid rgba(255,255,255,0.06); padding: 16px 24px; text-align: center;">
    <p style="font-size: 11px; color: rgba(255,255,255,0.2); font-family: 'Space Mono', monospace;">
      mediaVault — powered by Obsidian + Astro
    </p>
  </footer>

  <script>
    function init() {
      // Mobile nav toggle
      const toggle = document.querySelector('.nav-toggle');
      const links = document.querySelector('.nav-links');
      if (toggle && links) {
        toggle.addEventListener('click', () => {
          links.classList.toggle('open');
          toggle.classList.toggle('open');
        });
      }

      // Scroll reveal — IntersectionObserver
      const reveals = document.querySelectorAll('.reveal');
      if (reveals.length) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        reveals.forEach(el => observer.observe(el));
      }

      // Cover crowd scatter — driven by scroll position
      const crowdItems = document.querySelectorAll('.crowd-item');
      const crowdWrapper = document.querySelector('.crowd-wrapper');
      if (crowdItems.length && crowdWrapper) {
        const onScroll = () => {
          const rect = crowdWrapper.getBoundingClientRect();
          const wh = window.innerHeight;
          // progress: 0 when crowd is in view, 1 when scrolled past
          const progress = Math.max(0, Math.min(1, -rect.top / (rect.height + 100)));

          crowdItems.forEach(item => {
            const el = item as HTMLElement;
            const speed = parseFloat(el.dataset.speed || '0.5');
            const dir = el.dataset.dir === 'left' ? -1 : 1;
            const distance = progress * speed * window.innerWidth * 0.8;
            const fade = Math.max(0, 1 - progress * 1.5);
            el.style.transform = `translateX(${dir * distance}px) translateY(${el.style.getPropertyValue('--crowd-y') || '0px'})`;
            el.style.opacity = String(fade);
          });
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll(); // initial position
      }

      // Counter animation — counts from 0 to data-count
      const counters = document.querySelectorAll('[data-count]');
      if (counters.length) {
        const counterObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            const target = parseInt(el.dataset.count || '0', 10);
            if (!target) return;
            counterObserver.unobserve(el);
            const duration = 1200;
            const start = performance.now();
            const step = (now: number) => {
              const elapsed = now - start;
              const progress = Math.min(elapsed / duration, 1);
              // ease-out cubic
              const eased = 1 - Math.pow(1 - progress, 3);
              el.textContent = Math.round(eased * target).toString();
              if (progress < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
          });
        }, { threshold: 0.3 });
        counters.forEach(el => counterObserver.observe(el));
      }
    }

    // Run on initial load
    init();
    // Re-run after View Transitions navigate
    document.addEventListener('astro:after-swap', init);
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
